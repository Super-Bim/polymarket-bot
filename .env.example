# =============================================================
# POLYMARKET BOT — Credentials Configuration
# =============================================================
# Copy this file to .env and fill it with your credentials
# NEVER share the .env file

# --- Ethereum Wallet ---
# Your wallet's private key (starts with 0x)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Wallet and Signature Type ---
# SIGNATURE TYPE:
# 0 = Real Wallet / EOA (MetaMask, TrustWallet, Rabby, etc)
# 1 = Safe / Proxy Wallet (Polymarket accounts created via Email/Google)
# Note: For native transaction fee discount to work, you must use 0 (EOA).
SIGNATURE_TYPE=0

# Public Address where your funds (USDC) are stored
# - If using EOA (Type 0): Put your own public wallet address here and keep $MATIC in the wallet to pay for gas fees.
# - If using Proxy (Type 1): Put the proxy address (visible at polymarket.com/settings).
FUNDER_ADDRESS=0xYOUR_ADDRESS_HERE

# --- Polymarket CLOB API Keys ---
# Automatically generated by the bot on the first run
# (leave blank to auto-generate)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- Trading Parameters ---
# Base amount per trade in USDC (minimum recommended: 5)
TRADE_SIZE_USDC=5.0
